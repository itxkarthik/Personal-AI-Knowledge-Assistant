COGNOLITH_BACKEND_IMAGE=ghcr.io/itxkarthik/cognolith-backend:latest
COGNOLITH_FRONTEND_IMAGE=ghcr.io/itxkarthik/cognolith-frontend:latest
FRONTEND_PORT=8080
FRONTEND_HOST=https://knowledge.example.com
BACKEND_CORS_ORIGINS=["https://knowledge.example.com"]

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-generated-secret
POSTGRES_PASSWORD=replace-with-the-external-database-password
DATABASE_URL=postgresql+psycopg://cognolith:password@database.example.com:5432/cognolith?sslmode=require
DATABASE_SSL_MODE=require

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASSWORD=replace-with-an-app-password
SMTP_TLS=true
SMTP_SSL=false
EMAILS_FROM_EMAIL=sender@example.com
EMAILS_FROM_NAME=Cognolith

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-a-strong-password
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
