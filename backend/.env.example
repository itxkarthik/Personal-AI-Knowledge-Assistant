# Cognolith backend environment
# Copy to `backend/.env` for running the FastAPI backend outside Docker.
# Never commit `backend/.env` after adding real secrets.

# Project Info
PROJECT_NAME=Cognolith
PROJECT_DESCRIPTION=A connected workspace for knowledge, memory, and retrieval
VERSION=0.1.0
DEBUG=True
ENVIRONMENT=local  # local | staging | production

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Database Info
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_HOST=localhost
POSTGRES_DB=knowledge_assistant
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME_USE_STRONG_PASSWORD@localhost:5432/knowledge_assistant

# CORS Info
FRONTEND_HOST=http://localhost:8080
BACKEND_CORS_ORIGINS='["http://localhost:8080","http://127.0.0.1:8080","http://localhost:3000","http://127.0.0.1:3000"]'

# Security — Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# First Superuser
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS='[".pdf",".md",".docx",".txt"]'

# AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Email verification
# Local Docker users can keep Mailpit values in the root `.env`.
# For backend-only local development, run Mailpit separately or use Gmail SMTP.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=False
SMTP_SSL=False
EMAILS_FROM_EMAIL=no-reply@cognolith.local
EMAILS_FROM_NAME=Cognolith

# Gmail SMTP example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASSWORD=your-16-character-google-app-password
# SMTP_TLS=True
# SMTP_SSL=False
# EMAILS_FROM_EMAIL=your-gmail-address@gmail.com

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(levelname)s - %(message)s"
LOG_FILE="./logs/app.log"
